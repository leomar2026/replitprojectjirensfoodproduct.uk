# Jiren's Food Product — Environment Variables
# Copy this file to .env and fill in your values before starting.
# NEVER commit the real .env file to version control.

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Replit: DATABASE_URL is provisioned automatically.
# VPS:    Provide DATABASE_URL OR set all PG* variables individually.
DATABASE_URL=postgresql://user:password@host:5432/dbname
PGHOST=localhost
PGPORT=5432
PGDATABASE=jirens_food
PGUSER=jirens_app
PGPASSWORD=

# ── Session ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Set to your exact frontend domain in production (e.g. https://yourdomain.com)
CORS_ORIGIN=http://localhost:5000

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# ── File uploads ───────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5

# ── Backups ────────────────────────────────────────────────────────────────────
BACKUP_DIR=/var/backups/jirens
BACKUP_KEEP_DAYS=14

# ── Localisation ───────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=GBP
DEFAULT_TIMEZONE=Europe/London

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
